		"better-auth": "1.6.23",
		"drizzle-orm": "^0.45.2",
		"next": "16.2.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-server-dom-webpack": "^19.2.7",
		"vinext": "1.0.0-beta.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.43.3",
		"@eslint/eslintrc": "^3.3.5",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/node": "^26.1.1",
