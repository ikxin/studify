{
	"name": "studify",
	"type": "module",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "vinext dev",
		"build": "vinext build",
		"start": "vinext start",
		"lint": "eslint .",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
